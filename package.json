{
  "name": "agent-harness-lab",
  "version": "1.0.0",
  "description": "A TypeScript learning harness for coding-agent loops, tools, skills, subagents, and context compaction.",
  "main": "dist/main.js",
  "type": "module",
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "dev": "tsx src/main.ts",
    "dev:watch": "tsx watch src/main.ts",
    "test": "tsx --test tests/**/*.test.ts",
    "build": "pnpm clean && tsc",
    "start": "node dist/main.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@11.0.9",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "dotenv": "^17.4.2"
  }
}
